# =============================================================================
#  .env.example — Todas as variáveis de ambiente do projeto SCSI
#  Copie para .env e preencha os valores antes de rodar o projeto.
#  NUNCA versione o .env real com segredos!
# =============================================================================

# --- Django ---
SECRET_KEY=django-insecure-change-me-in-production-use-a-long-random-string
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1
CSRF_TRUSTED_ORIGINS=http://localhost:8000,http://127.0.0.1:8000

# --- Localização ---
TIME_ZONE=America/Sao_Paulo
LANGUAGE_CODE=pt-br

# --- Banco de dados ---
# Se DATABASE_URL for definida, sobrepõe as configurações individuais abaixo
DATABASE_URL=postgresql://scsi:scsi@localhost:5432/scsi
POSTGRES_DB=scsi
POSTGRES_USER=scsi
POSTGRES_PASSWORD=scsi

# --- Redis ---
REDIS_URL=redis://localhost:6379/0

# --- Celery ---
CELERY_BROKER_URL=redis://localhost:6379/0
CELERY_RESULT_BACKEND=redis://localhost:6379/0

# --- E-mail ---
EMAIL_BACKEND=django.core.mail.backends.console.EmailBackend
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_HOST_USER=seu@email.com
EMAIL_HOST_PASSWORD=sua_senha_app
EMAIL_USE_TLS=True
DEFAULT_FROM_EMAIL=SCSI <no-reply@scsi.digital>

# --- IA / LLM (Sprints futuras) ---
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
ANTHROPIC_API_KEY=
LANGSMITH_API_KEY=
